# Way2AGI Configuration
# Copy this file to .env and fill in your values

# Compute Network IPs
CONTROLLER_IP=
DESKTOP_IP=
LAPTOP_IP=
MOBILE_IP=

# API Keys
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
HF_TOKEN=

# SSH Configuration (use SSH keys instead of passwords)
CONTROLLER_SSH_USER=
DESKTOP_SSH_USER=
LAPTOP_SSH_USER=

# Ollama Ports (defaults)
OLLAMA_PORT=11434
LLAMA_CPP_PORT=8080

# Gateway/Daemon Ports
CONTROLLER_PORT=8050
DESKTOP_PORT=8100
LAPTOP_PORT=8150
MOBILE_PORT=8200
