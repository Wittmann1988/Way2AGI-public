# Way2AGI – nur in user/.env ausfuellen!
USER_MODEL_PREFIX=myagi
HF_USERNAME=dein-hf-name

# IPs werden automatisch erkannt – nur bei Bedarf ueberschreiben
# CONTROLLER_IP=192.168.1.10
# DESKTOP_IP=
# LAPTOP_IP=
# MOBILE_IP=

# API Keys (optional)
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# HF_TOKEN=

# Resource Budget
MAX_GPU_HOURS_PER_DAY=8
NIGHT_MODE_START=2
NIGHT_MODE_END=6
MAX_MODEL_STORAGE_GB=10
PAUSE_ALL_ON_LOW_POWER=true

# Consciousness & Self-Observation
ENABLE_CONSCIOUSNESS=true
ENABLE_SELF_OBSERVATION=true
REFLECTION_INTERVAL_MINUTES=10
